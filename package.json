{
  "name": "formforge-pdf-editor",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "displayName": "Formforge",
  "packageManager": "bun@1.3.3",
  "scripts": {
    "dev": "vite",
    "dev:app": "tauri dev",
    "build": "tsc --noEmit && vite build",
    "build:turbo": "turbo run build",
    "build:app": "tauri build",
    "preview": "bun run build:turbo && vite preview",
    "format": "prettier --write \"./src/**/*.{js,jsx,ts,tsx,css,html,json,md}\"",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . && bun run typecheck",
    "lint:eslint": "eslint .",
    "prepare": "husky"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx,css,html,json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@ai-sdk/deepseek": "^2.0.24",
    "@ai-sdk/google": "^3.0.43",
    "@ai-sdk/openai": "^3.0.41",
    "@ai-sdk/openai-compatible": "^2.0.35",
    "@cantoo/pdf-lib": "2.5.3",
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/geist-mono": "^5.2.7",
    "@fontsource/geist": "^5.2.8",
    "@lobehub/icons": "^5.0.1",
    "@openrouter/ai-sdk-provider": "^2.3.3",
    "@tailwindcss/vite": "^4.2.1",
    "@tauri-apps/plugin-cli": "~2.4.1",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "@tauri-apps/plugin-opener": "~2.5.3",
    "ai": "^6.0.116",
    "class-variance-authority": "0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.20",
    "dompurify": "^3.3.3",
    "emblor": "^1.4.8",
    "lucide-react": "0.555.0",
    "micromark": "^4.0.2",
    "micromark-extension-gfm": "^3.0.0",
    "next-themes": "^0.4.6",
    "pdf-fontkit": "^1.8.9",
    "pdfjs-dist": "^5.5.207",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-aria-components": "^1.16.0",
    "react-dom": "^19.2.4",
    "shadcn": "^3.8.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "wouter": "^3.9.0",
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.25.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/cli": "^2.10.1",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/wicg-file-system-access": "^2023.10.7",
    "@vitejs/plugin-react": "^5.2.0",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.8.17",
    "tw-animate-css": "^1.4.0",
    "typescript-eslint": "^8.57.1",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-static-copy": "^3.3.0"
  }
}
