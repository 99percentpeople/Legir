{
  "name": "legir-pdf-reader",
  "private": true,
  "version": "0.0.0",
  "license": "AGPL-3.0-or-later",
  "author": "Zach Yuen <yuenzach99@gmail.com>",
  "repository": "https://github.com/99percentpeople/Legir",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "displayName": "Legir",
  "packageManager": "bun@1.3.3",
  "scripts": {
    "dev": "vite",
    "dev:www": "bun run --cwd www dev",
    "dev:app": "tauri dev",
    "build": "tsc --noEmit && vite build",
    "build:www": "bun run --cwd www build",
    "build:turbo": "turbo run build",
    "build:app": "tauri build",
    "build:web:tauri": "turbo run build -- --mode tauri",
    "icons:generate": "bun scripts/generate-icons.ts",
    "icons:generate:app": "bun scripts/generate-icons.ts app",
    "icons:generate:pdf": "bun scripts/generate-icons.ts pdf",
    "preview": "bun run build:turbo && vite preview",
    "preview:www": "bun run --cwd www preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write \"./{src,www,tests,config}/**/*.{js,jsx,ts,tsx,css,html,json,md}\" \"./*.config.{js,ts}\"",
    "typecheck": "tsc --noEmit",
    "typecheck:www": "tsc --noEmit -p www/tsconfig.json",
    "lint": "eslint . && bun run typecheck && bun run typecheck:www",
    "lint:eslint": "eslint .",
    "prepare": "husky"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx,css,html,json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.79",
    "@ai-sdk/google": "^3.0.79",
    "@ai-sdk/groq": "^3.0.39",
    "@ai-sdk/openai": "^3.0.65",
    "@ai-sdk/openai-compatible": "^2.0.48",
    "@ai-sdk/xai": "^3.0.92",
    "@cantoo/pdf-lib": "2.5.3",
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/geist-mono": "^5.2.8",
    "@fontsource/geist": "^5.2.9",
    "@lobehub/icons": "^5.8.0",
    "@openrouter/ai-sdk-provider": "^2.9.0",
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/plugin-cli": "~2.4.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-opener": "~2.5.4",
    "ai": "^6.0.191",
    "class-variance-authority": "0.7.1",
    "clsx": "^2.1.1",
    "crypto-js": "^4.2.0",
    "dayjs": "^1.11.21",
    "dompurify": "^3.4.5",
    "emblor": "^1.4.8",
    "lucide-react": "0.555.0",
    "micromark": "^4.0.2",
    "micromark-extension-gfm": "^3.0.0",
    "next-themes": "^0.4.6",
    "pdf-fontkit": "^1.8.9",
    "pdfjs-dist": "^5.7.284",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-aria-components": "^1.17.0",
    "react-dom": "^19.2.6",
    "shadcn": "^3.8.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "vercel-minimax-ai-provider": "^0.0.2",
    "wouter": "^3.10.0",
    "zhipu-ai-provider": "^0.3.1",
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.25.2",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/cli": "^2.11.2",
    "@types/node": "^24.12.4",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/wicg-file-system-access": "^2023.10.7",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "@vitejs/plugin-react": "^5.2.0",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.4",
    "turbo": "^2.9.14",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^7.3.3",
    "vite-plugin-pwa": "^1.3.0",
    "vite-plugin-static-copy": "^3.4.0",
    "vitest": "^4.1.7"
  }
}
