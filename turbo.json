{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**",
        "public/**",
        "index.html",
        "vite.config.*",
        "tsconfig.json",
        "package.json"
      ],
      "outputs": ["dist/**"]
    }
  }
}
