{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "formforge-pdf-editor",
  "version": "0.1.0",
  "identifier": "com.99percentpeople.formforge",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "bun dev",
    "beforeBuildCommand": "bun x turbo run build"
  },
  "app": {
    "windows": [
      {
        "title": "formforge-pdf-editor",
        "width": 1280,
        "height": 800,
        "minWidth": 640,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "cli": {
      "description": "FormForge PDF Editor CLI",
      "args": [
        {
          "name": "source",
          "index": 1,
          "takesValue": true
        }
      ]
    }
  }
}
